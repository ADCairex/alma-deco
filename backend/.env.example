# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# PayPal (Sandbox)
PAYPAL_CLIENT_ID=secret_SANDBOX_CLIENT_ID
PAYPAL_CLIENT_SECRET=secret_SANDBOX_CLIENT_SECRET
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com

# Frontend URLs (adjust for production)
FRONTEND_SUCCESS_URL=http://localhost:5173/success
FRONTEND_CANCEL_URL=http://localhost:5173/cancel

# CORS — para ngrok añade la URL del frontend separada por coma:
# FRONTEND_ORIGIN=http://localhost:5173,https://yyy.ngrok-free.app
FRONTEND_ORIGIN=http://localhost:5173

# Database (use 'db' as host when running via Docker Compose, 'localhost' for local dev)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/almadeco
